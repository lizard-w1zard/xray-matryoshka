{
  "log": { "loglevel": "warning" },
  "inbounds": [
    {
      "port": 443,
      "protocol": "vless",
      "settings": {
        "clients": [{ "id": "{{ xray_exit_uuid }}", "flow": "" }],
        "decryption": "none"
      },
      "streamSettings": {
        "network": "xhttp",
        "sockopt": {
          "trustedXForwardedFor": [
            "{{ hostvars['transit']['ansible_host'] }}"
          ]
        },
        "security": "reality",
        "realitySettings": {
          "target": "{{ xray_exit_dest }}:443",
          "serverNames": ["{{ xray_exit_dest }}"],
          "privateKey": "{{ xray_exit_private_key }}",
          "shortIds": ["{{ xray_exit_short_id }}"],
          "mldsa65Seed": "{{ xray_exit_mldsa_seed }}"
        },
        "xhttpSettings": {
          "path": "/{{ xray_exit_xhttp_path | default('exit-stream') }}"
        }
      }
    }
  ],
  "outbounds": [
    {
      "tag": "direct",
      "protocol": "freedom",
      "settings": {}
    },
    {
      "tag": "blocked",
      "protocol": "blackhole",
      "settings": {}
    }
  ],
  "routing": {
    "domainStrategy": "IPIfNonMatch",
    "rules": [
      {
        "type": "field",
        "protocol": ["quic"],
        "outboundTag": "blocked"
      },
      {
        "type": "field",
        "ip": ["geoip:private"],
        "outboundTag": "blocked"
      }
    ]
  }
}