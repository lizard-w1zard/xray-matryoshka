{
  "log": { "loglevel": "warning" },
  "inbounds": [
    {
      "port": 443,
      "protocol": "vless",
      "settings": {
        "clients": [{ "id": "{{ xray_exit_uuid }}", "flow": "" }],
        "decryption": "none"
      },
      "streamSettings": {
        "network": "grpc",
        "security": "reality",
        "realitySettings": {
          "dest": "{{ xray_exit_dest }}:443",
          "serverNames": ["{{ xray_exit_dest }}"],
          "privateKey": "{{ xray_exit_private_key }}",
          "shortIds": ["{{ xray_exit_short_id }}"]
        },
        "grpcSettings": {
          "serviceName": "grpc"
        }
      }
    }
  ],
  "outbounds": [
    {
      "tag": "warp",
      "protocol": "wireguard",
      "settings": {
        "secretKey": "{{ xray_warp_private_key }}",
        "address": [
          "{{ xray_warp_ipv4 }}",
          "{{ xray_warp_ipv6 }}"
        ],
        "peers": [
          {
            "publicKey": "bmXOC+F1FxEMF9dyiK2H5/1SUtzH0JuVo51h2wPfgyo=",
            "endpoint": "162.159.192.1:2408"
          }
        ],
        "reserved": {{ xray_warp_reserved | default('[0, 0, 0]') }},
        "mtu": 1280
      }
    },
    {
      "tag": "direct",
      "protocol": "freedom",
      "settings": {}
    },
    {
      "tag": "blocked",
      "protocol": "blackhole",
      "settings": {}
    }
  ],
  "routing": {
    "domainStrategy": "IPIfNonMatch",
    "rules": [
      {
        "type": "field",
        "protocol": ["quic"],
        "outboundTag": "blocked"
      },
      {
        "type": "field",
        "ip": ["geoip:private"],
        "outboundTag": "blocked"
      }
    ]
  }
}