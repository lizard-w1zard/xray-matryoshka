{
  "log": {
    "access": "/var/log/xray/access.log",
    "error": "/var/log/xray/error.log",
    "loglevel": "warning"
  },
  "stats": {},
  "api": {
    "tag": "api",
    "services": [
      "StatsService"
    ]
  },
  "policy": {
    "levels": {
      "0": {
        "statsUserUplink": true,
        "statsUserDownlink": true
      }
    },
    "system": {
      "statsInboundUplink": true,
      "statsInboundDownlink": true,
      "statsOutboundUplink": true,
      "statsOutboundDownlink": true
    }
  },
  "inbounds": [
    {
      "tag": "main",
      "listen": "127.0.0.1",
      "port": 4443,
      "protocol": "vless",
      "acceptProxyProtocol": true,
      "settings": {
        "clients": [
          {
            "id": "{{ xray_entry_uuid }}",
            "flow": "",
            "email": "all_users"
          }
        ],
        "decryption": "none"
      },
      "streamSettings": {
        "network": "xhttp",
        "sockopt": {
          "acceptProxyProtocol": true,
          "trustedXForwardedFor": [
            "X-Forwarded-For"
          ]
        },
        "security": "reality",
        "realitySettings": {
          "show": false,
          "target": "{{ xray_entry_dest }}:443",
          "serverNames": [
            "{{ xray_entry_dest }}"
          ],
          "privateKey": "{{ xray_entry_private_key }}",
          "shortIds": [
            "{{ xray_entry_short_id }}"
          ],
          "mldsa65Seed": "{{ xray_entry_mldsa_seed }}"
        },
        "xhttpSettings": {
          "path": "/{{ xray_entry_xhttp_path | default('entry-stream') }}"
        }
      },
      "sniffing": {
        "enabled": true,
        "destOverride": [
          "http",
          "tls",
          "quic"
        ]
      }
    },
    {
      "tag": "api",
      "listen": "127.0.0.1",
      "port": 54321,
      "protocol": "dokodemo-door",
      "settings": {
        "address": "127.0.0.1"
      }
    }
  ],
  "outbounds": [
    {
      "tag": "proxy_to_germany",
      "protocol": "vless",
      "settings": {
        "vnext": [
          {
            "address": "{{ hostvars['transit']['ansible_host'] }}",
            "port": 443,
            "users": [
              {
                "id": "{{ xray_transit_uuid }}",
                "encryption": "none",
                "flow": ""
              }
            ]
          }
        ]
      },
      "streamSettings": {
        "network": "xhttp",
        "security": "reality",
        "realitySettings": {
          "fingerprint": "chrome",
          "serverName": "{{ xray_transit_dest }}",
          "publicKey": "{{ xray_entry_public_key }}",
          "shortId": "{{ xray_entry_short_id }}",
          "spiderX": "/",
          "mldsa65Verify": "{{ xray_transit_mldsa_public }}"
        },
        "xhttpSettings": {
          "path": "/{{ xray_transit_xhttp_path | default('transit-stream') }}"
        }
      }
    },
    {
      "tag": "direct",
      "protocol": "freedom",
      "settings": {}
    },
    {
      "tag": "blocked",
      "protocol": "blackhole",
      "settings": {}
    }
  ],
  "routing": {
    "domainStrategy": "IPIfNonMatch",
    "rules": [
      {
        "type": "field",
        "inboundTag": [
          "api"
        ],
        "outboundTag": "api"
      },
      {
        "type": "field",
        "protocol": [
          "quic"
        ],
        "outboundTag": "blocked"
      },
      {
        "type": "field",
        "ip": [
          "geoip:private"
        ],
        "outboundTag": "blocked"
      },
      {
        "type": "field",
        "domain": [
          "domain:ru",
          "domain:рф",
          "domain:su"
        ],
        "outboundTag": "direct"
      },
      {
        "type": "field",
        "ip": [
          "geoip:ru"
        ],
        "outboundTag": "direct"
      }
    ]
  }
}