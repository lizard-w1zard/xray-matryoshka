{
  "log": { "loglevel": "warning" },
  "inbounds": [
    {
      "port": 443,
      "protocol": "vless",
      "settings": {
        "clients": [{ "id": "{{ xray_transit_uuid }}", "flow": "" }],
        "decryption": "none"
      },
      "streamSettings": {
        "network": "grpc",
        "security": "reality",
        "realitySettings": {
          "dest": "{{ xray_transit_dest }}:443",
          "serverNames": ["{{ xray_transit_dest }}"],
          "privateKey": "{{ xray_entry_private_key }}",
          "shortIds": ["{{ xray_entry_short_id }}"]
        },
        "grpcSettings": {
          "serviceName": "grpc"
        }
      }
    }
  ],
  "outbounds": [
    {
      "tag": "forward_to_exit",
      "protocol": "vless",
      "settings": {
        "vnext": [
          {
            "address": "{{ hostvars['exit']['ansible_host'] }}",
            "port": 443,
            "users": [
              {
                "id": "{{ xray_exit_uuid }}",
                "encryption": "none",
                "flow": ""
              }
            ]
          }
        ]
      },
      "streamSettings": {
        "network": "grpc",
        "security": "reality",
        "realitySettings": {
          "fingerprint": "chrome",
          "serverName": "{{ xray_exit_dest }}",
          "publicKey": "{{ xray_exit_public_key }}",
          "shortId": "{{ xray_exit_short_id }}",
          "spiderX": "/"
        },
        "grpcSettings": {
          "serviceName": "grpc"
        }
      }
    }
  ]
}
